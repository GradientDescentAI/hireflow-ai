# ── PostgreSQL ──────────────────────────────────────────────
POSTGRES_USER=hireflow
POSTGRES_PASSWORD=hireflow_dev
POSTGRES_DB=hireflow
DATABASE_URL=postgresql+psycopg2://hireflow:hireflow_dev@localhost:5432/hireflow

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── MinIO (S3-compatible object store) ───────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=hireflow-cvs
MINIO_SECURE=false

# ── Auth ─────────────────────────────────────────────────────
JWT_SECRET=replace_with_32_char_random_string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ── LLM Providers ────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ── Email / SendGrid ─────────────────────────────────────────
SENDGRID_API_KEY=SG....
SENDGRID_FROM_EMAIL=riya@hireflow.in
SENDGRID_FROM_NAME=Riya (HireFlow AI)

# Inbound application email domain
APPLICATION_EMAIL_DOMAIN=hireflow.in
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=applications@hireflow.in
IMAP_PASSWORD=

# ── Environment ──────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO

# ── Secrets Vault (MVP: env-based; GA: HashiCorp Vault) ──────
VAULT_BACKEND=env          # env | hashicorp | aws_secrets_manager
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=

# ── LinkedIn Persona (stored in vault for production) ────────
LINKEDIN_RIYA_USERNAME=
LINKEDIN_RIYA_PASSWORD=
LINKEDIN_PROXY_URL=         # residential India proxy: http://user:pass@host:port

# ── Telegram ─────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=

# ── WhatsApp Business API (Pro tier) ─────────────────────────
GUPSHUP_API_KEY=
WATI_API_KEY=
